---
import { Icon } from 'astro-icon';
---

<section class="bg-primary-50 dark:bg-slate-800">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 text-md text-center font-medium flex flex-col items-center gap-2">
    <span class="font-bold">
      <Icon name="tabler:info-square" class="w-5 h-5 inline-block align-text-bottom" /> Status</span
    >
    <div class="flex gap-2">
      <img src="https://img.shields.io/badge/License-MIT-yellow.svg" alt="" />
      <img src="https://github.com/Fil-Language/Filc/actions/workflows/test.yml/badge.svg?branch=master" alt="" />
    </div>
  </div>
</section>
