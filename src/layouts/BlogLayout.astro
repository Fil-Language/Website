---
import BlogLink from '~/components/widgets/BlogLink.astro';
import Footer from '~/components/widgets/Footer.astro';
import Header from '~/components/widgets/Header.astro';
import Layout from '~/layouts/BaseLayout.astro';
import { BlogProp, MetaSEO, isCurrentBlog } from '~/types';

export interface Props {
  meta?: MetaSEO;
  blog?: BlogProp[];
  page?: BlogProp;
  title?: string;
  base?: string;
}

const { meta, blog, page, title, base } = Astro.props;

if (meta) {
  meta.title += ' - ' + title + ' - ' + page?.title;
}
---

<Layout {meta}>
  <Header />
  <main class="flex min-h-screen w-full md:w-3/4 mx-auto">
    <div class="bg-primary-50 dark:bg-slate-800 pl-2 pr-6 py-4 md:w-1/5 rounded-r md:rounded">
      {blog && blog.map((item) => <BlogLink base={base} blog={item} current={isCurrentBlog(item, page)} />)}
    </div>
    <div class="w-3/4 mx-auto blog">
      <slot />
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const elts = document.querySelectorAll('[to-expand]');
  elts.forEach((elt) => {
    elt.addEventListener('click', () => {
      elt.classList.toggle('rotate-90');
      elt.parentElement?.nextElementSibling?.classList.toggle('hidden');
      elt.parentElement?.nextElementSibling?.classList.toggle('block');
    });
  });
</script>
