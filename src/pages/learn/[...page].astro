---
import Layout from '~/layouts/BlogLayout.astro';
import { learns } from '~/content/learn/learn.astro';
import { SITE } from '~/config.mjs';
import { blogParams } from '~/types';

const { page } = Astro.params;

export function getStaticPaths() {
  return blogParams(learns);
}

const meta = {
  title: SITE.title,
  description: SITE.description,
  dontUseTitleTemplate: true,
};

const current = learns.find((item) => {
  return item.params?.page === page;
});

const Content = current?.content;
---

<Layout blog={learns} meta={meta} page={current?.title} title="Learn" base="/learn">
  {Content ? <Content /> : 'Content not found'}
</Layout>
